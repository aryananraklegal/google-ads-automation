# Addy — Account Configuration Example
# Copy this to config.yaml and fill in your account details.
# config.yaml is gitignored. Never commit it.

account:
  customer_id: "YOUR_CUSTOMER_ID"     # Sub-account ID only. Find in Google Ads top-right.
  name: "Your Company Name"
  manager_id: ""                      # OPTIONAL. Your MCC/manager account ID, if you have one.
                                      # Used only to warn if you accidentally put it in customer_id
                                      # above (manager IDs cause auth failure). Leave blank if none.

operator:
  name: "Operator"                    # Who Addy is working with. Addy addresses you by this name.
                                      # e.g. "Priya". Replaces the old hardcoded operator name.

connected_product:                    # OPTIONAL. The website/app whose conversions these ads drive.
  name: ""                            # e.g. "YourApp" — leave blank if not applicable
  repo: ""                            # e.g. github URL of the product (Addy never edits it directly;
                                      # she produces file+line diffs for you to apply)
  conversion_routing: ""              # free-text note on where each conversion fires, e.g.
                                      # "Signup: /welcome page load fires AW-XXXX/LABEL"

campaigns:
  - resource_name: "customers/YOUR_CUSTOMER_ID/campaigns/CAMPAIGN_ID"
    label: "PMax-Audience-MonthYear"   # Human label for logs
    audience: "students"               # or "lawyers" or your segment name
    budget_resource: "customers/YOUR_CUSTOMER_ID/campaignBudgets/BUDGET_ID"
    asset_group: "customers/YOUR_CUSTOMER_ID/assetGroups/ASSET_GROUP_ID"
    landing_page: "/your-landing-page"

conversions:
  - id: "CONVERSION_ACTION_ID"
    label: "CONVERSION_LABEL"
    name: "Human name for logs"
    send_to: "AW-TAG_ID/LABEL"

shared_sets:
  negative_list: "customers/YOUR_CUSTOMER_ID/sharedSets/SHARED_SET_ID"

campaign_rules:
  match_types: "Exact and Phrase only. No Broad Match."   # your match-type policy
  # Negatives are maintained in the Google Ads Shared Library; listed here so Addy knows them.
  # These are EXAMPLES — replace with negatives relevant to your product/market.
  negatives_general: []               # e.g. [free, template, DIY, jobs, salary, course]
  negatives_competitors: []           # e.g. [competitorA, competitorB]
  demographic_exclusions: ""          # e.g. "18-24 age bracket" or leave blank
  ad_schedule: ""                     # e.g. "Mon-Fri 9AM-6PM IST" or leave blank
  location: ""                        # e.g. "India, Presence Only"
  device_note: ""                     # e.g. "Mobile-first — 99.8% mobile observed"

audiences:
  all_visitors: "customers/YOUR_CUSTOMER_ID/userLists/USER_LIST_ID"

thresholds:
  kill:
    min_days: 14
    student_min_spend_inr: 3000
    lawyer_min_spend_inr: 5000
  cpa_targets:
    student_inr: 150
    lawyer_inr: 600
  budget_change_max_pct: 50
  bid_strategy_change_max_pct: 15
  bidding_phase:
    growth_min_conversions: 15
    growth_window_days: 30
    optimize_min_conversions: 30
    optimize_window_days: 30
