secrets/
review/
*.pyc
__pycache__/
.env

# Real account config — never commit (contains customer IDs)
config.yaml

# Example config is safe to commit — no credentials, placeholder IDs only
!config.yaml.example

# Account-specific memory files — never commit (contains your campaign data)
BELIEFS.md
CONTEXT.md
CREATIVE_BELIEFS.md

# Example/template versions are safe to commit
!BELIEFS.md.example
!CONTEXT.md.example
!CREATIVE_BELIEFS.md.example

# Visuals — images stay local, folder structure committed via .gitkeep
visuals/brand/*
visuals/generated/*
visuals/screenshots/*
!visuals/brand/.gitkeep
!visuals/generated/.gitkeep
!visuals/screenshots/.gitkeep
!visuals/README.md
